

all: disk.img

mbr.o : mbr.S
	as --32 $< -o $@

mbr.bin : mbr.o
	ld -melf_i386 -T mbr.ld $< -o $@

bootfile = csmwrapx64.efi
#bootfile = hello.bin

disk.img: mbr.bin $(bootfile)
	rm -f $@
	dd bs=512 count=67584 if=/dev/zero of=$@
	mkfs.fat -F32 $@
	dd if=$< of=$@ bs=1 seek=90 conv=notrunc
	mmd -i $@ ::/EFI
	mmd -i $@ ::/EFI/BOOT
	mcopy -i $@ $(bootfile) ::/EFI/BOOT/BOOTX64.EFI

.PHONY: clean
clean:
	rm -f *.img *.o *.bin


run-bin: $(IMG)
	qemu-system-i386 -drive format=raw,file=$< -net none

run-img : $(IMG)
	qemu-system-i386 -drive if=floppy,format=raw,file=disk.img -boot a -net\
 none

%/run : %
	@i=$< &&\
	if test $${i##*.} = "img"; then\
		make run-img IMG=$<;\
	else\
		if test $${i##*.} = "bin"; then\
			make run-bin IMG=$<;\
		fi;\
	fi

qemu_env=env -u GTK_PATH -u GTK_EXE_PREFIX -u GIO_MODULE_DIR -u GSETTINGS_SCHEMA_DIR -u LOCPATH -u GTK_IM_MODULE_FILE -u GTK_IM_MODULE -u GTK_MODULES -u XDG_DATA_DIRS -u XDG_DATA_HOME

OVMF = /usr/share/ovmf/OVMF.fd
QEMU = qemu-system-x86_64
DISK = disk.img

runit: $(DISK)
	$(QEMU) -bios $(OVMF) \
		-drive format=raw,file=$(DISK) \
		-net none \
		-smp 2 \
		-m 256M \
		-vga std


